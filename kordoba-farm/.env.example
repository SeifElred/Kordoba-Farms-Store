# Database (required). PostgreSQL, e.g. Supabase.
# Supabase: Project Settings → Database → Connection string (URI).
# If your PASSWORD contains @ : # / % etc., you must URL-encode it in the URL:
#   @ → %40   : → %3A   # → %23   / → %2F   % → %25
# Example:
# DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Admin panel (required for /admin)
ADMIN_PASSWORD="your-secure-password"
ADMIN_SESSION_SECRET="long-random-string-at-least-32-chars"

# Public app URL (required for Stripe redirects, sitemap, metadata). No trailing slash.
# Production: https://store.kordobafarms.com
NEXT_PUBLIC_APP_URL="https://store.kordobafarms.com"

# Stripe (required if you use checkout)
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# Optional: WhatsApp link (cart/float + Organization contactPoint in schema). Can also be set in Admin → Settings.
# Example: NEXT_PUBLIC_WHATSAPP_LINK="https://wa.me/601137600068"

# Optional: Google Business Profile URL – used in Organization/Store schema (sameAs).
NEXT_PUBLIC_GBP_URL="https://g.page/Kordoba+Farms"

# Optional: Redis. If unset, defaults to redis://localhost:6379 (not available on Vercel).
# Use e.g. Upstash Redis and set REDIS_URL for serverless.
# REDIS_URL="rediss://..."
# Required for Stripe Checkout and webhooks
